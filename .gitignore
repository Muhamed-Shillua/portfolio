# ============================

# Node.js & Frontend Portfolio .gitignore

# ============================

# Node modules

node_modules/

# Logs

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories

jspm_packages/

# Build output

/dist/
build/

# Runtime data

pids/
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover

lib-cov/

# Coverage directory used by tools like istanbul

coverage/
*.lcov

# nyc test coverage

.nyc_output/

# Grunt intermediate storage ([http://gruntjs.com/creating-plugins#storing-task-files](http://gruntjs.com/creating-plugins#storing-task-files))

.grunt/

# Bower dependency directory ([https://bower.io/](https://bower.io/))

bower_components/

# Compiled source # Optional if using TS or other preprocessors

*.tsbuildinfo

# Optional npm cache directory

.npm/

# Optional eslint cache

.eslintcache

# Mac system files

.DS_Store
.AppleDouble
.LSOverride

# Thumbnails

._*

# Files that might appear in the root of a volume

.Spotlight-V100
.Trashes

# Temporary files

*.swp
*.swo
*~

# IDE / Editor files

.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Environment variables

.env

# Public assets that can be rebuilt

/public/css/*.min.css
/public/js/*.min.js

# Backup files

*.bak
*.tmp
*.old

# Resume PDF (keep tracked if needed)

!public/Muhamed-Shillua-Backend-Developer-CV.pdf